{
  "manifest_version": 3,
  "name": "EchoScript",
  "version": "1.0",
  "permissions": ["tabCapture", "activeTab", "offscreen", "tabs", "webNavigation", "storage"],
  "host_permissions": ["http://10.0.0.100:8000/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
